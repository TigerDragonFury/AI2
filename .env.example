# =============================================================
# AdAvatar — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# =============================================================

# ── Database (Supabase) ──────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ── Supabase (Client) ────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── NextAuth.js ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary ───────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── HuggingFace ──────────────────────────────────────────────
# Get from: https://huggingface.co → Settings → Access Tokens
HUGGINGFACE_API_TOKEN=

# ── Redis / Upstash ──────────────────────────────────────────
# Get from: https://upstash.com → Redis → Connect → Node.js
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://[HOST]:6379

# ── JWT (API ↔ Worker) ────────────────────────────────────────
# Generate: openssl rand -base64 32
API_JWT_SECRET=

# ── Resend (Email) ────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ── Sentry ────────────────────────────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── TikTok ────────────────────────────────────────────────────
# Get from: https://developers.tiktok.com → App → Keys & credentials
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ── YouTube / Google ──────────────────────────────────────────
# Uses the same Google credentials as OAuth above, plus:
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Meta (Instagram + Facebook) ───────────────────────────────
# Get from: https://developers.facebook.com → App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── Snapchat ──────────────────────────────────────────────────
# Get from: https://business.snapchat.com → Apps
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ── Internal ──────────────────────────────────────────────────
API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
WORKER_URL=http://localhost:4001
PORT=4000
NODE_ENV=development
JWT_SECRET=
EMAIL_FROM=AdAvatar <noreply@adavatar.app>
